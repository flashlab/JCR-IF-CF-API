{
  "name": "jcr-query-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "seed:generate": "npx tsx scripts/seed.ts",
    "seed:local": "npx tsx scripts/seed.ts && wrangler d1 execute jcr-db --local --file=seed.sql",
    "seed:remote": "npx tsx scripts/seed.ts && wrangler d1 execute jcr-db --remote --file=seed.sql",
    "schema:local": "wrangler d1 execute jcr-db --local --file=schema.sql",
    "schema:remote": "wrangler d1 execute jcr-db --remote --file=schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.81.0"
  }
}
